---
---

<section id="pricing" class="flex w-full self-center flex-col items-center gap-14 mt-[120px] px-4">
  <!-- Header -->
  <div class="inline-flex flex-col items-center gap-8">
    <div class="inline-flex flex-col items-center gap-6">
      <h2 class="font-bold text-[#232323] text-[61px] text-center tracking-[0.35px] leading-[85.4px] whitespace-nowrap">
        Simple, transparent pricing for creators
      </h2>
      <p class="font-normal text-[#232323cc] text-xl text-center tracking-[-0.45px] leading-7 whitespace-nowrap">
        Choose the plan that fits your project scale. No hidden fees, just premium design.
      </p>
    </div>

    <!-- Billing toggle -->
    <div class="inline-flex items-center gap-5 pl-2 pr-5 py-2 bg-white rounded-[100px] border border-solid border-[#c6baaf]">
      <button
        id="monthly-btn"
        class="inline-flex items-center gap-2 pt-2 pb-3 px-6 rounded-[100px] overflow-hidden bg-[#121212] transition-colors"
      >
        <span class="font-medium text-white text-base tracking-[0] leading-6 whitespace-nowrap">Monthly</span>
      </button>

      <button
        id="yearly-btn"
        class="font-medium text-[#606977] text-base tracking-[0] leading-6 whitespace-nowrap transition-colors px-2"
      >
        Yearly <span class="text-[#232323]">(40% Off)</span>
      </button>
    </div>
  </div>

  <!-- Pricing cards -->
  <div class="flex items-center gap-6 w-full justify-center overflow-visible">
    <img
      class="w-[468px] h-[614px] mt-[-18px] mb-[-32px] ml-[-22px] flex-shrink-0"
      alt="Starter plan"
      src="/figmaAssets/plan-card-container.png"
    />
    <img
      class="w-[500px] h-[656px] mt-[-39px] mb-[-53px] flex-shrink-0"
      alt="Pro plan"
      src="/figmaAssets/plan-card-container-1.png"
    />
    <img
      class="w-[468px] h-[614px] mt-[-18px] mb-[-32px] mr-[-22px] flex-shrink-0"
      alt="Enterprise plan"
      src="/figmaAssets/plan-card-container-2.png"
    />
  </div>
</section>

<script>
  const monthlyBtn = document.getElementById("monthly-btn");
  const yearlyBtn = document.getElementById("yearly-btn");

  monthlyBtn?.addEventListener("click", () => {
    monthlyBtn.classList.add("bg-[#121212]");
    monthlyBtn.querySelector("span")?.classList.replace("text-[#606977]", "text-white");
    yearlyBtn?.classList.replace("text-[#232323]", "text-[#606977]");
  });

  yearlyBtn?.addEventListener("click", () => {
    monthlyBtn?.classList.remove("bg-[#121212]");
    monthlyBtn?.querySelector("span")?.classList.replace("text-white", "text-[#606977]");
    yearlyBtn?.classList.replace("text-[#606977]", "text-[#232323]");
  });
</script>
