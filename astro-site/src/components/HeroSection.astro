---
const navLinks = [
  { label: "About", href: "#about" },
  { label: "Elements", href: "#elements" },
  { label: "Pricing", href: "#pricing" },
  { label: "FAQ", href: "#faq" },
];

const trustedCompanies = [
  { icon: "/figmaAssets/icon-2.svg", name: "Acme Corp" },
  { icon: "/figmaAssets/icon-16.svg", name: "Vertex" },
  { icon: "/figmaAssets/icon-6.svg", name: "Orbit" },
  { icon: "/figmaAssets/icon-6.svg", name: "Quantum" },
  { icon: "/figmaAssets/icon-4.svg", name: "Blocks" },
  { icon: "/figmaAssets/icon-8.svg", name: "Nexus" },
];
---

<div class="w-full self-center flex flex-col bg-[#ebe8e2] rounded-[0px_0px_16px_16px]">
  <!-- Navigation Header -->
  <header class="flex self-center w-full max-w-[1320px] h-[88px] flex-col items-center px-8 py-0 bg-[#f1eee6] rounded-[0px_0px_16px_16px] border-b border-solid border-[#321b151a]">
    <div class="flex w-full items-center justify-between px-8 py-6">
      <!-- Logo -->
      <div class="inline-flex items-center gap-2">
        <div class="w-8 h-8 bg-[#232323] rounded-lg flex items-center justify-center flex-shrink-0">
          <img class="w-5 h-5" alt="Starter Kit logo" src="/figmaAssets/icon-1.svg" />
        </div>
        <span class="font-semibold text-[#232323] text-2xl tracking-[-0.44px] leading-7 whitespace-nowrap">
          Starter Kit
        </span>
      </div>

      <!-- Nav Links -->
      <nav class="inline-flex items-center gap-12">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="font-medium text-[#232323] text-base tracking-[-0.15px] leading-5 whitespace-nowrap hover:opacity-70 transition-opacity duration-200"
          >
            {link.label}
          </a>
        ))}
        <div class="inline-flex items-center gap-0.5 cursor-pointer hover:opacity-70 transition-opacity duration-200">
          <span class="font-medium text-[#232323] text-base tracking-[-0.15px] leading-5 whitespace-nowrap">
            Pages
          </span>
          <img class="w-4 h-4" alt="Arrow down" src="/figmaAssets/icon---24-px---arrow-down-.svg" />
        </div>
      </nav>

      <!-- CTA Button -->
      <a
        href="#pricing"
        class="inline-flex items-center justify-center gap-2.5 px-5 py-2.5 bg-[#232323] rounded-[999px] shadow-[0px_1px_2px_-1px_#0000001a,0px_1px_3px_#0000001a] font-medium text-[#ece5d8] text-base tracking-[-0.15px] leading-5 whitespace-nowrap hover:bg-[#3a3a3a] hover:scale-105 active:scale-95 transition-all duration-200"
      >
        Get Started
      </a>
    </div>
  </header>

  <!-- Hero Content -->
  <div class="flex w-full max-w-[1096px] self-center mt-[140px] flex-col items-center gap-16">
    <!-- Text Content -->
    <div class="flex flex-col w-full max-w-[1021px] items-center gap-10">
      <!-- Version Badge -->
      <div class="relative w-[211px] h-9 bg-[#f7f5f0] rounded-[999px] border border-solid border-[#23232333] shadow-[0px_1px_2px_-1px_#0000001a,0px_1px_3px_#0000001a] flex items-center">
        <div class="inline-flex items-center gap-2 pl-3.5">
          <div class="w-3.5 h-3.5 bg-[#232323] rounded-full border-[3px] border-solid border-[#e7e3de] flex-shrink-0"></div>
          <div class="inline-flex items-center gap-2">
            <span class="font-semibold text-[#232323] text-sm text-center tracking-[-0.15px] leading-5 whitespace-nowrap">
              Version 1.0 is now live
            </span>
            <img class="w-3.5 h-3.5" alt="Arrow" src="/figmaAssets/icon-15.svg" />
          </div>
        </div>
      </div>

      <!-- Headline + Subtitle + Buttons -->
      <div class="flex flex-col items-center gap-12 w-full">
        <div class="flex flex-col items-center gap-8 w-full">
          <div class="flex flex-col items-center gap-4 w-full">
            <h1 class="w-full font-bold text-[#232323] text-[88px] text-center tracking-[-2.20px] leading-[92.4px]">
              Build faster with a
            </h1>
            <h1
              class="w-full font-bold text-[88px] text-center tracking-[-2.20px] leading-[92.4px]"
              style="background: linear-gradient(180deg, #232323 0%, rgba(35,35,35,0.15) 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;"
            >
              foundation that breathes
            </h1>
          </div>

          <p class="w-[644px] font-normal text-[#232323b2] text-2xl text-center tracking-[0.07px] leading-[39px]">
            A minimalist starter template designed for developers who value
            clean aesthetics and rapid deployment.
          </p>
        </div>

        <!-- CTA Buttons -->
        <div class="inline-flex items-center gap-4">
          <a
            href="#pricing"
            class="w-[235px] h-[60px] bg-black rounded-[80px] flex items-center justify-center gap-2 font-medium text-[#ece5d8] text-base text-center tracking-[-0.31px] leading-6 whitespace-nowrap hover:bg-[#333333] hover:scale-105 active:scale-95 transition-all duration-200"
          >
            Get Started for Free
            <img class="w-4 h-4" alt="Arrow" src="/figmaAssets/text.svg" />
          </a>

          <a
            href="#about"
            class="w-[242px] h-[60px] rounded-[80px] border border-solid border-[#23232333] bg-transparent flex items-center justify-center gap-2 font-medium text-[#232323] text-base text-center tracking-[-0.31px] leading-6 whitespace-nowrap hover:bg-[#23232308] hover:scale-105 active:scale-95 transition-all duration-200"
          >
            <img class="w-4 h-4" alt="Docs" src="/figmaAssets/icon-5.svg" />
            View Documentation
          </a>
        </div>
      </div>
    </div>

    <!-- Code Editor Mockup -->
    <div class="relative w-full h-[540px] overflow-hidden flex items-center justify-center group">
      <div class="w-[1101px] h-[542px] bg-[#232323] rounded-[20px] overflow-hidden border border-solid border-[#ffffff1a] shadow-[0px_30.58px_61.16px_-14.68px_#321b1566] relative transition-transform duration-500 group-hover:-translate-y-2">
        <!-- Editor title bar -->
        <div class="absolute top-px left-px w-[1091px] h-[93px] bg-[#ffffff0d] border-b border-solid border-[#ffffff1a]">
          <div class="flex w-[67px] h-4 items-start gap-[9.76px] absolute top-10 left-7">
            <div class="w-[16px] h-[15px] bg-[#ff5f56] rounded-full"></div>
            <div class="w-[16px] h-[15px] bg-[#ffbd2e] rounded-full"></div>
            <div class="w-[16px] h-[15px] bg-[#27c93f] rounded-full"></div>
          </div>
          <div class="flex items-center justify-center absolute top-[30px] left-[93px] w-[958px]">
            <div class="relative w-[130px] h-[32px] bg-[#ffffff0d] rounded-[10px] flex items-center gap-2 px-3">
              <img class="w-[15px] h-[15px]" alt="File icon" src="/figmaAssets/icon-11.svg" />
              <span class="font-normal text-[#ece5d866] text-[14.7px]">index.tsx</span>
            </div>
          </div>
        </div>

        <!-- Code content -->
        <div class="absolute top-[100px] left-[43px] flex flex-col gap-0 font-mono text-[19.6px] leading-[31.8px]">
          <div class="flex items-start gap-5">
            <span class="text-[#ece5d84c] w-5 text-right">1</span>
            <span class="text-[#ff7b72]">import</span>
            <span class="text-[#ece5d8cc]"> {"{ "}</span>
            <span class="text-[#d2a8ff]">StarterTemplate</span>
            <span class="text-[#ece5d8cc]"> {"} "}</span>
            <span class="text-[#ff7b72]">from</span>
            <span class="text-[#a5d6ff]"> '@ivory/ui';</span>
          </div>
          <div class="flex items-start gap-5">
            <span class="text-[#ece5d84c] w-5 text-right">2</span>
            <span class="text-[#ff7b72]">import</span>
            <span class="text-[#a5d6ff]"> './theme.css';</span>
          </div>
          <div class="flex items-start gap-5">
            <span class="text-[#ece5d84c] w-5 text-right">3</span>
          </div>
          <div class="flex items-start gap-5">
            <span class="text-[#ece5d84c] w-5 text-right">4</span>
            <span class="text-[#ff7b72]">export default function</span>
            <span class="text-[#d2a8ff]"> App</span>
            <span class="text-[#ece5d8cc]">() {"{"}</span>
          </div>
          <div class="flex items-start gap-5">
            <span class="text-[#ece5d84c] w-5 text-right">5</span>
            <span class="ml-8 text-[#ff7b72]">return</span>
            <span class="text-[#ece5d8cc]"> (</span>
          </div>
          <div class="flex items-start gap-5">
            <span class="text-[#ece5d84c] w-5 text-right">6</span>
            <span class="ml-16">
              <span class="text-[#79c0ff]">&lt;</span><span class="text-[#7ee787]">StarterTemplate</span>
            </span>
          </div>
          <div class="flex items-start gap-5">
            <span class="text-[#ece5d84c] w-5 text-right">7</span>
            <span class="ml-24 text-[#a5d6ff]">theme="ivory-cocoa"</span>
          </div>
          <div class="flex items-start gap-5">
            <span class="text-[#ece5d84c] w-5 text-right">8</span>
            <span class="ml-24 text-[#a5d6ff]">performance={"{100}"}</span>
          </div>
          <div class="flex items-start gap-5">
            <span class="text-[#ece5d84c] w-5 text-right">9</span>
            <span class="ml-16 text-[#7ee787]">/&gt;</span>
          </div>
          <div class="flex items-start gap-5">
            <span class="text-[#ece5d84c] w-5 text-right">10</span>
            <span class="ml-8 text-[#ece5d8cc]">);</span>
          </div>
          <div class="flex items-start gap-5">
            <span class="text-[#ece5d84c] w-5 text-right">11</span>
            <span class="text-[#ece5d8cc]">{"}"}</span>
          </div>
        </div>
      </div>

      <!-- Centered overlay image -->
      <img
        class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[168px] h-[168px] transition-transform duration-500 group-hover:scale-110 group-hover:rotate-6"
        alt="Container"
        src="/figmaAssets/container-1.svg"
      />
    </div>
  </div>

  <!-- Trusted By Section -->
  <div class="flex w-full max-w-[1320px] self-center mt-20 mb-10 flex-col items-center gap-8">
    <p class="w-full font-semibold text-[#232323cc] text-sm text-center tracking-[2.65px] leading-5">
      TRUSTED BY INNOVATIVE TEAMS WORLDWIDE
    </p>
    <div class="flex items-center justify-between w-full">
      {trustedCompanies.map((company) => (
        <div class="inline-flex items-center gap-2 hover:opacity-70 transition-opacity duration-200">
          <img class="w-8 h-8" alt={company.name} src={company.icon} />
          <span class="font-bold text-[#23232380] text-xl tracking-[-0.45px] leading-7 whitespace-nowrap">
            {company.name}
          </span>
        </div>
      ))}
    </div>
  </div>
</div>
