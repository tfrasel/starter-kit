---
const pagesLinks = ["Authors", "Categories", "Tags", "FAQ"];
const productLinks = ["Features", "Pricing", "Guide"];
const legalLinks = ["Privacy Policy", "Terms of Service"];
const communityLinks = [
  { label: "GitHub", icon: "/figmaAssets/icon.svg" },
  { label: "Discord", icon: "/figmaAssets/icon---24-px---discordlogo-.svg" },
  { label: "Twitter", icon: "/figmaAssets/icon-10.svg" },
];
---

<footer class="w-full mt-[120px] flex flex-col items-center bg-black rounded-t-[24px] overflow-hidden">
  <!-- Main footer content -->
  <div class="flex w-full max-w-[1320px] mt-[120px] items-start justify-between px-8">
    <!-- Brand / Description -->
    <div class="flex flex-col w-[313px] items-start gap-4">
      <div class="inline-flex items-center gap-2">
        <!-- Logo on dark bg — icon already uses light stroke, visible here -->
        <img class="w-6 h-6" alt="Starter Kit logo" src="/figmaAssets/icon-1.svg" />
        <span class="font-semibold text-[#f1eee6] text-2xl tracking-[-0.44px] leading-7 whitespace-nowrap">
          Starter Kit
        </span>
      </div>
      <p class="self-stretch font-normal text-[#f1eee6b2] text-base tracking-[-0.15px] leading-[26px]">
        A minimalist starter template designed for developers who value clean aesthetics and rapid deployment.
      </p>
    </div>

    <!-- Navigation columns -->
    <nav class="inline-flex items-start gap-[120px]">
      <!-- Pages -->
      <div class="flex flex-col w-[83px] items-start gap-8">
        <span class="font-semibold text-[#f1eee6] text-xl tracking-[-0.31px] leading-6">Pages</span>
        <ul class="flex flex-col items-start gap-4 w-full list-none p-0 m-0">
          {pagesLinks.map((link) => (
            <li>
              <a href="#" class="font-medium text-[#f1eee699] text-base tracking-[-0.15px] leading-5 whitespace-nowrap no-underline hover:text-[#f1eee6] transition-colors">
                {link}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Product -->
      <div class="inline-flex flex-col items-start gap-8">
        <span class="font-semibold text-[#f1eee6] text-xl tracking-[-0.31px] leading-6 whitespace-nowrap">Product</span>
        <ul class="flex flex-col items-start gap-2 w-full list-none p-0 m-0">
          {productLinks.map((link) => (
            <li>
              <a href="#" class="font-medium text-[#f1eee6cc] text-base tracking-[-0.15px] leading-5 whitespace-nowrap no-underline hover:text-[#f1eee6] transition-colors">
                {link}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Legal -->
      <div class="flex flex-col w-[127px] items-start gap-8">
        <span class="font-semibold text-[#f1eee6] text-xl tracking-[-0.31px] leading-6">Legal</span>
        <ul class="flex flex-col items-start gap-4 w-full list-none p-0 m-0">
          {legalLinks.map((link) => (
            <li>
              <a href="#" class="font-medium text-[#f1eee6cc] text-base tracking-[-0.15px] leading-5 no-underline hover:text-[#f1eee6] transition-colors">
                {link}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Community -->
      <div class="flex flex-col w-28 items-start gap-8">
        <span class="font-semibold text-[#f1eee6] text-xl tracking-[-0.31px] leading-6">Community</span>
        <ul class="flex flex-col items-start gap-4 list-none p-0 m-0">
          {communityLinks.map((item) => (
            <li class="flex items-center gap-2">
              <img class="w-4 h-4" alt={item.label} src={item.icon} />
              <a href="#" class="font-medium text-[#f1eee6cc] text-base tracking-[-0.15px] leading-5 whitespace-nowrap no-underline hover:text-[#f1eee6] transition-colors">
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </nav>
  </div>

  <!-- Divider -->
  <div class="w-full max-w-[1320px] mt-[119px] px-8">
    <div class="w-full h-px bg-[#f1eee620]"></div>
  </div>

  <!-- Copyright -->
  <div class="w-full max-w-[1320px] mt-8 mb-8 px-8 flex items-start">
    <p class="font-normal text-[#f1eee699] text-base tracking-[-0.15px] leading-5 whitespace-nowrap">
      © 2026 Starter Kit. All rights reserved.
    </p>
  </div>
</footer>
